#!/usr/bin/env bash
set -euo pipefail

PROG="$(basename "$0")"
ARCHIVE_FILE="${YT_ARCHIVE_FILE:-archive.txt}"
SUB_LANGS="${YT_ARCHIVE_SUB_LANGS:-en.*}"
COOKIES_FROM_BROWSER="${YT_ARCHIVE_COOKIES_FROM_BROWSER-chrome}"
COOKIES_FILE="${YT_ARCHIVE_COOKIES:-}"

usage() {
  cat <<EOF
usage: $PROG [options] <channel-handle-or-url> [extra yt-dlp args]

Archive a YouTube channel/playlist/video with dated filenames, embedded
metadata/thumbnail/subs (human-made only), and incremental re-runs via a
download archive file.

Accepts a bare @handle (e.g. @ChannelName), which expands to that channel's
/videos tab, or any full yt-dlp-supported URL.

Options:
  -s, --size       Estimate total download size without downloading anything.
  -c, --confirm    Show the size estimate and prompt before downloading.
  -h, --help       Show this help.

Environment:
  YT_ARCHIVE_FILE                  Path to the download-archive file (default: archive.txt)
  YT_ARCHIVE_SUB_LANGS              Subtitle languages to embed (default: en.*)
  YT_ARCHIVE_COOKIES_FROM_BROWSER   Browser to read cookies from (default: chrome; also accepts
                                     safari, firefox, etc). Set to empty to disable. Used to pass
                                     YouTube's sign-in/bot verification.
  YT_ARCHIVE_COOKIES                Path to a Netscape-format cookies.txt file (alternative to
                                     YT_ARCHIVE_COOKIES_FROM_BROWSER, e.g. for headless use)

Examples:
  $PROG @ChannelName
  $PROG "https://www.youtube.com/@ChannelName/videos"
  $PROG --size @ChannelName
  $PROG --confirm @ChannelName
  $PROG "https://www.youtube.com/@ChannelName/videos" --playlist-end 20
  YT_ARCHIVE_COOKIES_FROM_BROWSER=safari $PROG @ChannelName
  YT_ARCHIVE_COOKIES_FROM_BROWSER= $PROG @ChannelName  # disable cookie use
EOF
}

normalize_url() {
  local input="$1"
  case "$input" in
    @*)
      # bare handle, e.g. @dungeonchill or @dungeonchill/streams
      if [[ "$input" == */* ]]; then
        echo "https://www.youtube.com/$input"
      else
        echo "https://www.youtube.com/$input/videos"
      fi
      ;;
    *)
      echo "$input"
      ;;
  esac
}

require_yt_dlp() {
  if ! command -v yt-dlp >/dev/null 2>&1; then
    echo "$PROG: yt-dlp not found on PATH. Install it first (e.g. brew install yt-dlp)." >&2
    exit 1
  fi
}

cookie_args() {
  local -n out="$1"
  out=()
  [[ -n "$COOKIES_FROM_BROWSER" ]] && out+=(--cookies-from-browser "$COOKIES_FROM_BROWSER")
  [[ -n "$COOKIES_FILE" ]] && out+=(--cookies "$COOKIES_FILE")
  return 0
}

human_size() {
  # bytes -> human-readable (base 1024), via awk for portability
  awk -v bytes="$1" 'BEGIN {
    split("B KiB MiB GiB TiB", units, " ")
    size = bytes
    i = 1
    while (size >= 1024 && i < 5) {
      size /= 1024
      i++
    }
    printf "%.2f %s", size, units[i]
  }'
}

estimate_size() {
  local url="$1"
  shift
  require_yt_dlp

  local count=0 total=0 known=0 unknown=0 size
  local cookies=()
  cookie_args cookies

  while IFS= read -r size; do
    count=$((count + 1))
    if [[ "$size" == "NA" ]]; then
      unknown=$((unknown + 1))
    else
      known=$((known + 1))
      total=$((total + size))
    fi
    printf '\rScanning... %d video(s), ~%s so far' "$count" "$(human_size "$total")" >&2
  done < <(yt-dlp \
    --skip-download \
    --download-archive "$ARCHIVE_FILE" \
    -f "bv*+ba/b" \
    -O "%(filesize,filesize_approx)s" \
    -i \
    "${cookies[@]+"${cookies[@]}"}" \
    "$@" \
    "$url")

  if [[ "$count" -gt 0 ]]; then
    printf '\n' >&2
  fi

  echo "Estimated size: ~$(human_size "$total") across $known video(s) with known size"
  if [[ "$unknown" -gt 0 ]]; then
    echo "Note: $unknown video(s) had no size metadata and are excluded from the total."
  fi

  # exported for --confirm to reuse without re-running yt-dlp
  ESTIMATE_TOTAL="$total"
  ESTIMATE_KNOWN="$known"
  ESTIMATE_UNKNOWN="$unknown"
}

download() {
  local url="$1"
  shift
  require_yt_dlp

  local cookies=()
  cookie_args cookies

  yt-dlp \
    -o "%(uploader)s/%(upload_date)s - %(title)s [%(id)s].%(ext)s" \
    --download-archive "$ARCHIVE_FILE" \
    -f "bv*+ba/b" \
    --merge-output-format mp4 \
    --embed-metadata \
    --embed-thumbnail \
    --embed-subs \
    --sub-langs "$SUB_LANGS" \
    -i \
    "${cookies[@]+"${cookies[@]}"}" \
    "$@" \
    "$url"
}

main() {
  local mode="download"
  local url=""
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      -s|--size)
        mode="size"
        shift
        ;;
      -c|--confirm)
        mode="confirm"
        shift
        ;;
      *)
        if [[ -z "$url" ]]; then
          url="$1"
        else
          extra_args+=("$1")
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$url" ]]; then
    usage >&2
    exit 1
  fi

  url="$(normalize_url "$url")"

  case "$mode" in
    size)
      estimate_size "$url" "${extra_args[@]+"${extra_args[@]}"}"
      ;;
    confirm)
      estimate_size "$url" "${extra_args[@]+"${extra_args[@]}"}"
      read -r -p "Download ~$(human_size "$ESTIMATE_TOTAL") across $ESTIMATE_KNOWN video(s)? [y/N] " reply
      case "$reply" in
        [yY]|[yY][eE][sS])
          download "$url" "${extra_args[@]+"${extra_args[@]}"}"
          ;;
        *)
          echo "Aborted."
          exit 1
          ;;
      esac
      ;;
    download)
      download "$url" "${extra_args[@]+"${extra_args[@]}"}"
      ;;
  esac
}

main "$@"
